# === DATABASE ===
DATABASE_URL="file:./db/custom.db"

# === KOTAK NEO BROKER (Paper Trading) ===
# Kotak Neo API credentials - get from https://neo.kotaksecurities.com
KOTAK_NEO_CONSUMER_KEY=your_consumer_key_here
KOTAK_NEO_CONSUMER_SECRET=your_consumer_secret_here
KOTAK_NEO_ACCESS_TOKEN=your_access_token_here
KOTAK_NEO_TOTP_SECRET=your_totp_secret_here  # For 2FA login
KOTAK_NEO_MPIN=your_mpin_here
KOTAK_NEO_SESSION_ID=your_session_id_here     # Auto-generated after login

# === AI / LLM ===
# OpenAI or compatible LLM for trade scoring and analysis
OPENAI_API_KEY=your_openai_api_key_here
AI_MODEL=gpt-4o

# === TELEGRAM BOT (Alerts) ===
# Create bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALERT_CHAT_ID=your_chat_id_here       # Where to send alerts

# === TELEGRAM READER (Read signals from groups) ===
# Telethon API credentials - get from https://my.telegram.org
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_PHONE=+919XXXXXXXXX                    # Your phone number

# === OPTIONAL SETTINGS ===
# Default lot size (1 until capital reaches 10000)
DEFAULT_LOT_SIZE=1
# Capital at which to start scaling lots
SCALE_CAPITAL_THRESHOLD=10000
# Max loss per trade as % of capital
MAX_LOSS_PERCENT=5
