# ============================================
# JSS SAWRIYA SETH WEALTHTECH - CONFIG
# ============================================
# Copy this file as .env and fill your values:
#   copy .env.example .env
# ============================================

# === DATABASE ===
DATABASE_URL="file:./db/custom.db"

# === KOTAK NEO BROKER CREDENTIALS ===
# Yeh sabhi values aapke Kotak Neo account se milegi
KOTAK_CLIENT_CODE=XV3ZT
KOTAK_ACCESS_TOKEN=your_access_token_here
KOTAK_MOBILE=+91XXXXXXXXXX
KOTAK_MPIN=your_mpin_here
KOTAK_TOTP_SECRET=your_totp_secret_here

# === AI / LLM (Trade Scoring) ===
# OpenAI ya compatible API key for AI analysis
OPENAI_API_KEY=your_openai_api_key_here
AI_MODEL=gpt-4o

# === TELEGRAM BOT (Trade Alerts bhejne ke liye) ===
# @BotFather se bot banao, token yahan daalo
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALERT_CHAT_ID=your_chat_id_here

# === TELEGRAM READER (Groups se signals padhne ke liye) ===
# https://my.telegram.org se API ID/Hash lo
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_PHONE=+91XXXXXXXXXX

# === TRADING SETTINGS ===
# Lot size = 1 jab tak capital 10000 na ho
DEFAULT_LOT_SIZE=1
# 10000 ke baad lots scale honge
SCALE_CAPITAL_THRESHOLD=10000
# Ek trade me max loss (capital ka %)
MAX_LOSS_PERCENT=5
